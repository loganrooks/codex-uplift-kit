{
  "_codexUpliftNotes": [
    "Sample only: inactive until promoted or merged into an active hooks layer such as ~/.codex/hooks.json or trusted project .codex config.",
    "Hooks are Codex lifecycle guardrails. They can reduce common mistakes, but they are not a complete security boundary.",
    "Keep sandbox and approval settings conservative even when hook samples are active."
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.codex/hooks/pretool-protect-git.mjs",
            "timeout": 30,
            "statusMessage": "Checking shell command for destructive git patterns"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.codex/hooks/stop-audit-shape.mjs",
            "timeout": 30,
            "statusMessage": "Checking final response audit shape"
          }
        ]
      }
    ]
  }
}
